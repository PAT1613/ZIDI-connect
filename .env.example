# ===== Django =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated. In prod, list your public hostname(s); no wildcards.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Full scheme + host (comma-separated) for browser POST endpoints.
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
# CORS whitelist for browser-based clients (web frontend). Native mobile bypasses CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== PostgreSQL =====
POSTGRES_DB=zidi_connect
POSTGRES_USER=zidi
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== JWT =====
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=7

# ===== Webhook shared secret =====
# Required for server-to-server webhooks (Africa's Talking delivery reports).
# Callers must send it in the `X-Webhook-Secret` header, or the request is 403.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SHARED_SECRET=

# ===== SMS — Africa's Talking =====
# These values are the fallback. Once you save credentials via Settings → Integrations
# in the UI, the DB values take precedence so you can rotate keys without restarting.
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=ZIDI

# ===== Email (SMTP) =====
# Same precedence rule as above — UI-saved SMTP creds override these.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=ZIDI Connect <noreply@zidi.local>

# ===== Company branding (used on invoices and email footer) =====
COMPANY_NAME=ZIDI Connect
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_ADDRESS=

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ===== Admin bootstrap (used by entrypoint.sh) =====
# Both EMAIL and PASSWORD must be set for the entrypoint to create a superuser.
# If either is empty, no superuser is created on boot — use
# `docker compose exec backend python manage.py createsuperuser` instead.
# NEVER commit real credentials here.
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FULL_NAME=Super Admin
